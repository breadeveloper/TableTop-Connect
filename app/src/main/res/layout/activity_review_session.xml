<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/reviewHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Ended!"
            android:textColor="#FC7A57"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvReviewGameName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marvels Rival Co-op"
            android:textColor="#2D2B30"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvUrgencyWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFF3E0"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFB74D"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/reviewHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please submit your anonymous ratings."
                android:textColor="#E65100"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDeadlineTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Due by: Calculating..."
                android:textColor="#D32F2F"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Failure to submit will result in an automatic -1.0 Reputation penalty."
                android:textColor="#E65100"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/cvUrgencyWarning"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmitReviews">

        <LinearLayout
            android:id="@+id/playerReviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSubmitReviews"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="16dp"
        android:backgroundTint="#FC7A57"
        android:text="SUBMIT REVIEWS"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>